local function ValidarKey(key)
    local ok, res = pcall(function()
        return request({ Url = KEYS_URL, Method = "GET" })
    end)
    if not ok or not res or not res.Body then return false end
    local dok, data = pcall(function() return HttpService:JSONDecode(res.Body) end)
    if not dok or not data or not data.keys then return false end
    for _, k in ipairs(data.keys) do
        if k == key then return true end
    end
    return false
end

