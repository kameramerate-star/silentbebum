            local kn             = tostring(input.KeyCode):gsub("Enum.KeyCode.", "")
            keyBadgePB.Text      = kn
            keyBadgePB2.Text     = kn
            keyBadgePB.TextColor3  = Color3.fromRGB(180, 180, 180)
            keyBadgePB2.TextColor3 = Color3.fromRGB(180, 180, 180)
            SaveConfig()
        end
        return
    end
    if isListeningForMenu then
        if input.KeyCode ~= Enum.KeyCode.Unknown then
            MENU_KEY             = input.KeyCode
            isListeningForMenu   = false
            local kn             = tostring(input.KeyCode):gsub("Enum.KeyCode.", "")
            keyBadge6.Text       = kn
            keyBadge6.TextColor3 = Color3.fromRGB(180, 180, 180)
            UpdateFooter()
            SaveConfig()
        end
        return
    end

    if gameProcessed then return end

    -- Astral keys
    if input.KeyCode == SILENT_KEY then
        TELEGUIADO_ENABLED    = not TELEGUIADO_ENABLED
        dot1.BackgroundColor3 = TELEGUIADO_ENABLED and GREEN or RED
        if TELEGUIADO_ENABLED then ALWAYS_ACTIVE = false dotAA.BackgroundColor3 = RED end
    end
    if input.KeyCode == PB_KEY then
        PB_ENABLED             = not PB_ENABLED
        dotPB.BackgroundColor3 = PB_ENABLED and GREEN or RED
    end
    if input.KeyCode == MENU_KEY then
        mainFrame.Visible = not mainFrame.Visible
    end

    -- Trocar alvo pelo TARGET_CYCLE_KEY
    if input.KeyCode == TARGET_CYCLE_KEY then
        local players = {}
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= LocalPlayer then table.insert(players, p) end
        end
        if #players == 0 then return end
        local idx = 0
        if SelectedTarget then
            for i, p in ipairs(players) do
                if p == SelectedTarget then idx = i break end
            end
        end
        idx = (idx % #players) + 1
        SelectedTarget = players[idx]
        targetStatusLbl.Text       = "alvo: " .. SelectedTarget.Name
        targetStatusLbl.TextColor3 = Color3.fromRGB(200, 150, 255)
        RefreshTargetList()
    end

    -- Clara keys
    if input.KeyCode == ClaraKeys.Fly         then flyRowC.Trigger()    end
    if input.KeyCode == ClaraKeys.TpWalk      then tpWalkRowC.Trigger() end
    if input.KeyCode == ClaraKeys.Noclip      then noclipRowC.Trigger() end
    if input.KeyCode == ClaraKeys.InfJump     then infJumpRowC.Trigger() end
    if input.KeyCode == ClaraKeys.ESP         then espRowC.Trigger()    end
    if input.KeyCode == ClaraKeys.ToggleClara then claraFrame.Visible = not claraFrame.Visible end

    -- Click TP
    if input.UserInputType == Enum.UserInputType.MouseButton1 and clickTpEnabled then
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) or UserInputService:IsKeyDown(Enum.KeyCode.RightControl) then
            local _, myRoot, _ = getLocalCharacterData()
            local mouse = LocalPlayer:GetMouse()
            if myRoot and mouse and mouse.Target then
                myRoot.CFrame = CFrame.new(mouse.Hit.X, mouse.Hit.Y + 3, mouse.Hit.Z)
            end
        end
    end
end)

