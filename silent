local function IsCharacterBeingMoved()
    local char = LocalPlayer.Character
    if not char then return false end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return false end
    if root:FindFirstChildOfClass("BodyVelocity")        then return true end
    if root:FindFirstChildOfClass("BodyPosition")        then return true end
    if root:FindFirstChildOfClass("BodyGyro")            then return true end
    if root:FindFirstChildOfClass("BodyAngularVelocity") then return true end
    if root:FindFirstChildOfClass("BodyThrust")          then return true end
    if root:FindFirstChildOfClass("LinearVelocity")      then return true end
    if root:FindFirstChildOfClass("AngularVelocity")     then return true end
    if root:FindFirstChildOfClass("AlignPosition")       then return true end
    if root:FindFirstChildOfClass("AlignOrientation")    then return true end
    if root:FindFirstChildOfClass("VectorForce")         then return true end
    if dashActive then return true end
    if tick() - dashCooldown < 1.0 then return true end
    return false
end

