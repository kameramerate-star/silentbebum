RunService.Heartbeat:Connect(function()
    local _, myRoot, _ = getLocalCharacterData()
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then
            local char = plr.Character
            local data = tracked[plr]
            if char and char.Parent then
                if not data or not data.billboard or not data.billboard.Parent then
                    pcall(function() createESP(plr) end)
                    data = tracked[plr]
                end
                if data then
                    local targetRoot = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso") or char:FindFirstChild("Head")
                    if myRoot and targetRoot then
                        local dist = (targetRoot.Position - myRoot.Position).Magnitude
                        data.distLbl.Text = string.format("Dist: %.0fm", dist)
                    end
                    local hum = char:FindFirstChildOfClass("Humanoid")
                    if hum then
                        local maxHp   = hum.MaxHealth > 0 and hum.MaxHealth or 100
                        local percent = math.clamp(hum.Health / maxHp, 0, 1)
                        data.healthBar.Size = UDim2.new(percent, 0, 1, 0)
                        data.hpLbl.Text = string.format("HP: %d/%d", math.floor(hum.Health), math.floor(maxHp))
                    end
                    data.mdLbl.Text = "MD: " .. GetMD(plr)
                end
            else
                if data then removeESP(plr) end
            end
        end
    end
end)
