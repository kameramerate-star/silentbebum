local function GetDistStr(p)
    if not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then return "?" end
    if not p.Character or not p.Character:FindFirstChild("HumanoidRootPart") then return "?" end
    return tostring(math.floor((p.Character.HumanoidRootPart.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude)) .. "m"
end

local function RefreshTargetList()
    for _, b in pairs(playerButtons) do b:Destroy() end
    playerButtons = {}
    for _, p in pairs(Players:GetPlayers()) do
        if p == LocalPlayer then continue end
        local isSel = (SelectedTarget == p)
        local btn              = Instance.new("TextButton")
        btn.Size               = UDim2.new(1, 0, 0, 34)
        btn.BackgroundColor3   = isSel and Color3.fromRGB(50, 25, 80) or BG_ROW
        btn.BorderSizePixel    = 0
        btn.Text               = ("  %s  [%s]"):format(p.Name, GetDistStr(p))
        btn.TextColor3         = isSel and Color3.fromRGB(200, 150, 255) or Color3.fromRGB(190, 190, 190)
        btn.TextSize           = 12
        btn.Font               = Enum.Font.Gotham
        btn.TextXAlignment     = Enum.TextXAlignment.Left
        btn.LayoutOrder        = 0
        btn.Parent             = playerListFrame
        Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
        playerButtons[p.Name] = btn

        btn.MouseButton1Click:Connect(function()
            if SelectedTarget == p then
                SelectedTarget = nil
                targetStatusLbl.Text       = "alvo: automático (FOV)"
                targetStatusLbl.TextColor3 = Color3.fromRGB(100, 100, 100)
            else
                SelectedTarget = p
                targetStatusLbl.Text       = "alvo: " .. p.Name
                targetStatusLbl.TextColor3 = Color3.fromRGB(200, 150, 255)
            end
            RefreshTargetList()
        end)
    end
end

