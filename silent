local function GetMD(player)
    local char = player.Character
    if not char then return "—" end
    local data = tracked[player]
    if data and data.mdValue and data.mdValue.Parent then return math.floor(data.mdValue.Value) end
    local success, result = pcall(function()
        local paths = {
            {"combat","mode"},{"combat","Mode"},{"Combat","mode"},{"Combat","Mode"},
            {"Mode"},{"mode"},{"currentMode"},{"CombatMode"}
        }
        for _, path in ipairs(paths) do
            local obj = char
            local found = true
            for _, p in ipairs(path) do
                obj = obj:FindFirstChild(p)
                if not obj then found = false break end
            end
            if found and obj and obj.Value ~= nil then
                if data then data.mdValue = obj end
                return math.floor(obj.Value)
            end
        end
        for _, obj in ipairs(char:GetDescendants()) do
            if (obj:IsA("IntValue") or obj:IsA("NumberValue")) then
                local nl = obj.Name:lower()
                if nl:find("mode") or nl:find("md") or nl:find("stance") then
                    if data then data.mdValue = obj end
                    return math.floor(obj.Value)
                end
            end
        end
        return "—"
    end)
    return success and result or "—"
end

local function removeESP(player)
    if tracked[player] then
        pcall(function() if tracked[player].billboard then tracked[player].billboard:Destroy() end end)
        tracked[player] = nil
    end
end

