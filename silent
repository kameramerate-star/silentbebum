local function LoadConfig()
    EnsureFolder()
    if not isfile(CONFIG_FILE) then return end
    local ok, raw = pcall(readfile, CONFIG_FILE)
    if not ok or not raw then return end

    local function getBool(key) local v = raw:match('"' .. key .. '":(%a+)') return v == "true" end
    local function getNum(key)  local v = raw:match('"' .. key .. '":(%d+)') return v and tonumber(v) or nil end
    local function getStr(key)  return raw:match('"' .. key .. '":"([^"]+)"') end
    local function applyKey(str, target, field)
        if str then local e = Enum.KeyCode[str] if e then target[field] = e end end
    end

    local fovRadius   = getNum("fovRadius")
    local maxDistance = getNum("maxDistance")
    if fovRadius   then FOV_RADIUS       = fovRadius   end
    if maxDistance then MAX_DISTANCE_AIM = maxDistance end
    FOV_VISIBLE = getBool("fovVisible")
    applyKey(getStr("silentKey"),      _G, "SILENT_KEY_TMP")
    if _G.SILENT_KEY_TMP    then SILENT_KEY       = _G.SILENT_KEY_TMP    end
    applyKey(getStr("menuKey"),        _G, "MENU_KEY_TMP")
    if _G.MENU_KEY_TMP      then MENU_KEY         = _G.MENU_KEY_TMP      end
    applyKey(getStr("pbKey"),          _G, "PB_KEY_TMP")
    if _G.PB_KEY_TMP        then PB_KEY           = _G.PB_KEY_TMP        end
    applyKey(getStr("targetCycleKey"), _G, "TC_KEY_TMP")
    if _G.TC_KEY_TMP        then TARGET_CYCLE_KEY = _G.TC_KEY_TMP        end
    local hc = getStr("hubColor")
    if hc then HUB_COLOR = HexToColor(hc) end

    ClaraKeysDefault.Fly         = getStr("flyKey")         or ClaraKeysDefault.Fly
    ClaraKeysDefault.Noclip      = getStr("noclipKey")      or ClaraKeysDefault.Noclip
    ClaraKeysDefault.InfJump     = getStr("infJumpKey")     or ClaraKeysDefault.InfJump
    ClaraKeysDefault.TpWalk      = getStr("tpWalkKey")      or ClaraKeysDefault.TpWalk
    ClaraKeysDefault.ESP         = getStr("espKey")         or ClaraKeysDefault.ESP
    ClaraKeysDefault.ToggleClara = getStr("claraKey")       or ClaraKeysDefault.ToggleClara

    local fs = getNum("flySpeed")    if fs then flySpeed      = fs end
    local ts = getNum("tpWalkSpeed") if ts then tpWalkSpeed   = ts end
    local cz = getNum("cameraZoom")  if cz then maxCameraZoom = cz end

    flying         = getBool("flying")
    noclipping     = getBool("noclipping")
    infJumpEnabled = getBool("infJump")
    tpWalkEnabled  = getBool("tpWalk")
    espEnabled     = getBool("esp")
    antiAfkEnabled = getBool("antiAfk")
    clickTpEnabled = getBool("clickTp")
end
LoadConfig()

